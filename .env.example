# Host port used to reach Scene Map.
SCENE_MAP_PORT=8787

# Defaults to the newest stable release. Set an immutable version for controlled
# upgrades and rollback, for example ghcr.io/swilcox/kdrama-graph:0.1.0.
SCENE_MAP_IMAGE=ghcr.io/swilcox/kdrama-graph:latest

# Host directories mounted into the container. Absolute paths are recommended
# on a server, for example /srv/scene-map/data and /srv/scene-map/backups.
SCENE_MAP_DATA_DIR=./data
SCENE_MAP_BACKUP_DIR=./backups

TZ=America/Chicago
