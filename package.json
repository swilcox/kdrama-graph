{
  "name": "kdrama-graph",
  "private": true,
  "version": "0.3.0",
  "type": "module",
  "packageManager": "pnpm@11.13.1",
  "scripts": {
    "dev": "concurrently -k -n api,web -c green,cyan \"pnpm dev:api\" \"pnpm dev:web\"",
    "dev:api": "tsx watch server/index.ts",
    "dev:web": "vite --host 0.0.0.0",
    "build": "tsc -b && vite build",
    "start": "tsx server/index.ts",
    "test": "node --import tsx --test server/*.test.ts"
  },
  "dependencies": {
    "cheerio": "^1.2.0",
    "express": "^5.1.0",
    "lucide-react": "^1.24.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tsx": "^4.23.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/express": "^5.0.3",
    "@types/node": "^24.0.10",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^6.0.3",
    "concurrently": "^10.0.3",
    "typescript": "~7.0.2",
    "vite": "^8.1.4"
  }
}
